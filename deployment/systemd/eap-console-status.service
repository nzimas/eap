[Unit]
Description=Electroacoustic Playground console ready display
After=getty@tty1.service eap-jack.service eap-supercollider.service eap-dexed.service eap-dexed-connect.service eap-launchpad.service
Wants=getty@tty1.service eap-jack.service eap-supercollider.service eap-dexed.service eap-dexed-connect.service eap-launchpad.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/eap-console-status /dev/tty1
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
