[Unit]
Description=Electroacoustic Playground headless Dexed
After=eap-jack.service
Requires=eap-jack.service

[Service]
Type=simple
User=we
Environment=HOME=/home/we
Environment=XDG_CONFIG_HOME=/home/we/.config
Environment=XDG_DATA_HOME=/home/we/.local/share
ExecStart=/usr/local/bin/eap-start-dexed
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
