[Unit]
Description=Electroacoustic Playground JACK server
After=sound.target
Conflicts=norns-jack.service

[Service]
Type=simple
User=we
Group=audio
Environment=JACK_NO_AUDIO_RESERVATION=1
LimitRTPRIO=95
LimitMEMLOCK=infinity
ExecStart=/usr/bin/jackd -R -P 95 -d alsa -d hw:sndrpiproto -r 48000 -n 3 -p 256 -S -s
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
