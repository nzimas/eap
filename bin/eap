#!/usr/bin/env python3
"""Electroacoustic Playground control CLI."""

import argparse
import socket
import sys


def _osc_string(value: str) -> bytes:
    data = value.encode("utf-8") + b"\0"
    padding = (4 - (len(data) % 4)) % 4
    return data + (b"\0" * padding)


def _osc_int(value: int) -> bytes:
    return int(value).to_bytes(4, byteorder="big", signed=True)


def send_scene(scene_count: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/scenes") + _osc_string(",i") + _osc_int(scene_count)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_slot(slot: int, action: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/slot") + _osc_string(",ii") + _osc_int(slot) + _osc_int(action)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_reverb(param: int, value: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/reverb") + _osc_string(",ii") + _osc_int(param) + _osc_int(value)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_master(param: int, value: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/master") + _osc_string(",ii") + _osc_int(param) + _osc_int(value)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_session(slot: int, action: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/session") + _osc_string(",ii") + _osc_int(slot) + _osc_int(action)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_tuning(scale: int, root: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/tuning") + _osc_string(",ii") + _osc_int(scale) + _osc_int(root)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_engine(engine_code: int, host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/engine") + _osc_string(",i") + _osc_int(engine_code)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_dexed_rescan(host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/dexed/rescan") + _osc_string(",i") + _osc_int(1)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def send_vcv_rescan(host: str = "127.0.0.1", port: int = 57120) -> None:
    packet = _osc_string("/eap/vcv/rescan") + _osc_string(",i") + _osc_int(1)
    with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as sock:
        sock.sendto(packet, (host, port))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="eap")
    engine_codes = {
        "plaits": 1,
        "rings": 2,
        "passersby": 3,
        "molly": 4,
        "dexed": 5,
        "vital": 6,
    }
    parser.add_argument(
        "--seedscene",
        nargs="?",
        const="random",
        help="Generate a fresh scene set using the currently selected engine. Any legacy name is ignored.",
    )
    parser.add_argument("--host", default="127.0.0.1", help=argparse.SUPPRESS)
    parser.add_argument("--port", default=57120, type=int, help=argparse.SUPPRESS)
    parser.add_argument(
        "--n",
        default=1,
        type=int,
        help="Number of simultaneous scene layers to run for this manual seed, capped at 8.",
    )
    parser.add_argument("--slot", type=int, help="Toggle a single scene slot, 1-8.")
    parser.add_argument(
        "--regenerate",
        action="store_true",
        help="With --slot, replace that slot with a fresh random scene.",
    )
    parser.add_argument("--reverb-param", type=int, help="Set master reverb parameter column, 1-8.")
    parser.add_argument("--master-param", type=int, help="Set master dynamics/degradation parameter column, 1-5.")
    parser.add_argument("--session", type=int, help="Load a session slot, 1-64.")
    parser.add_argument("--save-session", type=int, help="Save the current state to a session slot, 1-64.")
    parser.add_argument("--scale", type=int, help="Set scale index, 0-7.")
    parser.add_argument("--root", type=int, default=0, help="With --scale, set root note as semitone, C=0 through B=11.")
    parser.add_argument("--engine", choices=sorted(engine_codes), help="Select the source engine for future scene generation.")
    parser.add_argument("--dexed-rescan", action="store_true", help="Rescan for a headless Dexed MIDI destination.")
    parser.add_argument("--vcv-rescan", action="store_true", help="Rescan for a headless VCV Rack MIDI destination.")
    parser.add_argument("--value", type=int, default=64, help="Value for --reverb-param or --master-param, 0-127.")
    args = parser.parse_args(argv)
    scene_count = max(1, min(args.n, 8))

    if args.engine is not None:
        send_engine(engine_codes[args.engine], args.host, args.port)
        if args.seedscene is None and args.slot is None:
            print(f"selected engine: {args.engine}")
            return 0

    if args.reverb_param is not None:
        param = max(1, min(args.reverb_param, 8))
        value = max(0, min(args.value, 127))
        send_reverb(param, value, args.host, args.port)
        print(f"set reverb param {param}: {value}")
        return 0

    if args.master_param is not None:
        param = max(1, min(args.master_param, 5))
        value = max(0, min(args.value, 127))
        send_master(param, value, args.host, args.port)
        print(f"set master param {param}: {value}")
        return 0

    if args.save_session is not None:
        slot = max(1, min(args.save_session, 64))
        send_session(slot, 1, args.host, args.port)
        print(f"saved session slot: {slot}")
        return 0

    if args.session is not None:
        slot = max(1, min(args.session, 64))
        send_session(slot, 0, args.host, args.port)
        print(f"loaded session slot: {slot}")
        return 0

    if args.scale is not None:
        scale = max(0, min(args.scale, 7))
        root = max(0, min(args.root, 11))
        send_tuning(scale, root, args.host, args.port)
        print(f"set tuning scale {scale}, root {root}")
        return 0

    if args.dexed_rescan:
        send_dexed_rescan(args.host, args.port)
        print("rescanned Dexed MIDI destination")
        return 0

    if args.vcv_rescan:
        send_vcv_rescan(args.host, args.port)
        print("rescanned VCV Rack MIDI destination")
        return 0

    if args.slot is not None:
        slot = max(1, min(args.slot, 8))
        action = 1 if args.regenerate else 0
        send_slot(slot, action, args.host, args.port)
        print(("regenerated" if action else "toggled") + f" scene slot: {slot}")
        return 0

    if args.seedscene:
        send_scene(scene_count, args.host, args.port)
        print(f"seeded random scenes: {scene_count}")
        return 0

    parser.print_help()
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
